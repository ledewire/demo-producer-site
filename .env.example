# LedeWire API base URL
# Production (default — used when this var is unset):
#   LEDEWIRE_BASE_URL=https://api.ledewire.com
# Staging (point here during development to avoid hitting production data):
#   LEDEWIRE_BASE_URL=https://api.staging.ledewire.com
LEDEWIRE_BASE_URL=https://api.ledewire.com

# Session encryption secret — generate with: openssl rand -hex 32
# MUST be at least 32 characters
SESSION_SECRET=replace_with_a_32_plus_char_random_secret

# Google OAuth Client ID
# No longer required as an environment variable — the app fetches the Google
# client ID from the LedeWire API at request time via client.config.getPublic().
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
